{
  "app": "npx ts-node --prefer-ts-exts bin/app.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "node_modules",
      "dist",
      "resources",
      "scripts"
    ]
  },
  "context": {
    "amazonLinuxCpuType": "ARM_64",
    "instanceType": "m7g.xlarge",
    "volumeSize": 30,
    "sshKeyName": "",
    "sshCidr": "0.0.0.0/0",
    "minecraftPort": 25565,
    "hostedZoneName": "broccoli-dependence.stichiboi.com",
    "serverSubdomain": "minecraft",
    "idleShutdownTimer": 900,
    "javaVersion": "21"
  }
}
